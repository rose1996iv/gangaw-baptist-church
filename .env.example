# =============================================
# Grace Baptist Church — Environment Variables
# =============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ----- Database -----
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/gbc?retryWrites=true&w=majority

# ----- Payload CMS -----
PAYLOAD_SECRET=replace-with-min-32-char-random-secret-string

# ----- NextAuth -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-nextauth-secret

# ----- Facebook / Meta -----
# From Meta Developer Console → Your App → Settings → Basic
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
NEXT_PUBLIC_FACEBOOK_APP_ID=

# ----- Church Info (used in UI) -----
NEXT_PUBLIC_CHURCH_NAME=Grace Baptist Church
NEXT_PUBLIC_CHURCH_TAGLINE=A Community of Faith, Hope & Love
NEXT_PUBLIC_CHURCH_ADDRESS=123 Main Street, Anytown, USA 00000
NEXT_PUBLIC_CHURCH_PHONE=(555) 123-4567
NEXT_PUBLIC_CHURCH_EMAIL=info@gracebaptist.org
NEXT_PUBLIC_SERVICE_TIMES=Sundays: 9:00 AM & 11:00 AM | Wednesdays: 7:00 PM

# ----- YouTube -----
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_YOUTUBE_LIVE_VIDEO_ID=

# ----- PayPal -----
NEXT_PUBLIC_PAYPAL_ME_LINK=https://www.paypal.me/YourChurchHandle

# ----- Email via Resend (free tier) -----
# Get API key at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@gracebaptist.org
RESEND_PRAYER_TO_EMAIL=pastor@gracebaptist.org
